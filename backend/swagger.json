{
  "openapi": "3.0.0",
  "info": {
    "title": "AdVantage API",
    "version": "1.0.0",
    "description": "API documentation for the AdVantage reselling platform, separated into B2C (Public/Buyer) and B2B (Seller/Manager/Admin) surfaces."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Development server"
    }
  ],
  "tags": [
    {
      "name": "B2C - Public Discovery",
      "description": "Endpoints accessible without authentication (Home, Search)"
    },
    {
      "name": "B2C - Auth & Profile",
      "description": "Buyer login, signup, OTP, and profile management"
    },
    {
      "name": "B2C - Buyer Operations",
      "description": "Wishlist, Requests, Orders, Payments, and filing Complaints"
    },
    {
      "name": "B2C - Chat & Notifications",
      "description": "User messaging and notification tracking"
    },
    {
      "name": "B2B - Seller Operations",
      "description": "Manage products, accept/reject requests, seller analytics, and subscriptions"
    },
    {
      "name": "B2B - Manager Operations",
      "description": "Manager dashboards, product verification, and complaint resolution"
    },
    {
      "name": "B2B - Admin Operations",
      "description": "Platform metrics, graph data, and managing system users"
    }
  ],
  "paths": {
    "/auth/google": {
      "post": {
        "summary": "Sign in / register via Google id token",
        "tags": [
          "B2C - Auth & Profile"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "idToken"
                ],
                "properties": {
                  "idToken": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Google login successful"
          }
        }
      }
    },
    "/auth/signup": {
      "post": {
        "summary": "Create a new buyer account (sends verification OTP)",
        "tags": [
          "B2C - Auth & Profile"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "username",
                  "contact",
                  "email",
                  "password"
                ],
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "contact": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "OTP sent to email"
          }
        }
      }
    },
    "/auth/verify-email": {
      "post": {
        "summary": "Verify email with OTP and create account",
        "tags": [
          "B2C - Auth & Profile"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "code"
                ],
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "code": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email verified and account created (returns token)"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Buyer login",
        "tags": [
          "B2C - Auth & Profile"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful (sets token cookie)"
          }
        }
      }
    },
    "/auth/logout": {
      "delete": {
        "summary": "Logout user (clears token cookie)",
        "tags": [
          "B2C - Auth & Profile"
        ],
        "responses": {
          "200": {
            "description": "Logged out successfully"
          }
        }
      }
    },
    "/auth/admin/login": {
      "post": {
        "summary": "Admin login",
        "tags": [
          "B2B - Admin Operations"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Admin login successful"
          }
        }
      }
    },
    "/auth/manager/login": {
      "post": {
        "summary": "Manager login",
        "tags": [
          "B2B - Manager Operations"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Manager login successful"
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "summary": "Get current user info",
        "tags": [
          "B2C - Auth & Profile"
        ],
        "responses": {
          "200": {
            "description": "Current user info returned"
          }
        }
      }
    },
    "/chat/contacts": {
      "get": {
        "summary": "Retrieve user contact list",
        "tags": [
          "B2C - Chat & Notifications"
        ],
        "responses": {
          "200": {
            "description": "A list of contacts"
          }
        }
      }
    },
    "/chat/createContact/{id}": {
      "post": {
        "summary": "Create a new contact connection",
        "tags": [
          "B2C - Chat & Notifications"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the user to add as a contact"
          }
        ],
        "responses": {
          "201": {
            "description": "Contact created successfully"
          }
        }
      }
    },
    "/chat/messages/{id}": {
      "get": {
        "summary": "Get message history with a specific contact",
        "tags": [
          "B2C - Chat & Notifications"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of messages"
          }
        }
      }
    },
    "/chat/message/{id}": {
      "post": {
        "summary": "Send a message to a contact",
        "tags": [
          "B2C - Chat & Notifications"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "newMessage": {
                    "type": "object",
                    "properties": {
                      "sender": {
                        "type": "string"
                      },
                      "message": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent"
          }
        }
      }
    },
    "/anyone/HomeRequirements": {
      "get": {
        "summary": "Get featured and fresh products",
        "tags": [
          "B2C - Public Discovery"
        ],
        "responses": {
          "200": {
            "description": "Successful response with featured and fresh products",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "freshProducts": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "featuredProducts": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/anyone/products/filtered": {
      "get": {
        "summary": "Get products with optional filters",
        "tags": [
          "B2C - Public Discovery"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "name",
            "schema": {
              "type": "string"
            },
            "description": "Partial or full product name to search"
          },
          {
            "in": "query",
            "name": "category",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "verified",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "in": "query",
            "name": "minPrice",
            "schema": {
              "type": "number"
            }
          },
          {
            "in": "query",
            "name": "maxPrice",
            "schema": {
              "type": "number"
            }
          },
          {
            "in": "query",
            "name": "postingDate",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "ISO date string to filter postings after this date"
          }
        ],
        "responses": {
          "200": {
            "description": "List of products",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "products": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/anyone/products/{productId}": {
      "get": {
        "summary": "Get product details by ID",
        "tags": [
          "B2C - Public Discovery"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "productId",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Product identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Product retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "product": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Product not found"
          }
        }
      }
    },
    "/admin": {
      "get": {
        "summary": "Retrieve aggregated admin dashboard data",
        "tags": [
          "B2B - Admin Operations"
        ],
        "responses": {
          "200": {
            "description": "Aggregated data returned successfully"
          }
        }
      }
    },
    "/admin/graphData": {
      "get": {
        "summary": "Get product graph data for admin dashboard",
        "tags": [
          "B2B - Admin Operations"
        ],
        "responses": {
          "200": {
            "description": "Graph data returned successfully"
          }
        }
      }
    },
    "/admin/metrics": {
      "get": {
        "summary": "Get computed admin metrics",
        "tags": [
          "B2B - Admin Operations"
        ],
        "responses": {
          "200": {
            "description": "Metrics returned successfully"
          }
        }
      }
    },
    "/admin/paymentAnalytics": {
      "get": {
        "summary": "Get payment analytics and trends",
        "tags": [
          "B2B - Admin Operations"
        ],
        "responses": {
          "200": {
            "description": "Payment analytics returned successfully"
          }
        }
      }
    },
    "/admin/addManager": {
      "post": {
        "summary": "Add a new manager user",
        "tags": [
          "B2B - Admin Operations"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password",
                  "category"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string"
                  },
                  "category": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Manager created successfully"
          }
        }
      }
    },
    "/admin/remove/{userId}": {
      "delete": {
        "summary": "Remove a user by id",
        "tags": [
          "B2B - Admin Operations"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "userId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User removed successfully"
          }
        }
      }
    },
    "/admin/removeManager/{managerId}": {
      "delete": {
        "summary": "Remove a manager by id",
        "tags": [
          "B2B - Admin Operations"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "managerId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Manager removed successfully"
          }
        }
      }
    },
    "/manager/d": {
      "get": {
        "summary": "Get manager dashboard data (unverified products for manager category)",
        "tags": [
          "B2B - Manager Operations"
        ],
        "responses": {
          "200": {
            "description": "Dashboard products returned successfully"
          }
        }
      }
    },
    "/manager/verify": {
      "post": {
        "summary": "Verify a product (manager action)",
        "tags": [
          "B2B - Manager Operations"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "pid"
                ],
                "properties": {
                  "pid": {
                    "type": "string",
                    "description": "Product id to verify"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Product verified successfully"
          }
        }
      }
    },
    "/manager/complaints": {
      "get": {
        "summary": "Get complaints for manager's category",
        "tags": [
          "B2B - Manager Operations"
        ],
        "responses": {
          "200": {
            "description": "Complaints returned successfully"
          }
        }
      }
    },
    "/manager/complaints/{complaintId}": {
      "patch": {
        "summary": "Resolve a complaint by id",
        "tags": [
          "B2B - Manager Operations"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "complaintId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string"
                  },
                  "resolution": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Complaint resolved successfully"
          }
        }
      }
    },
    "/user/request/{productId}": {
      "post": {
        "summary": "Request a product (place a bid)",
        "tags": [
          "B2C - Buyer Operations"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "productId",
            "required": true,
            "schema": {
              "type": "string",
              "example": "65fd5ec5b93fa2f0f7a11234"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "biddingPrice": {
                    "type": "number"
                  }
                }
              },
              "example": {
                "biddingPrice": 14500
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Request sent successfully"
          }
        }
      }
    },
    "/user/paymentDone/{productId}": {
      "post": {
        "summary": "Confirm payment for a product",
        "tags": [
          "B2C - Buyer Operations"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "productId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Payment confirmed"
          }
        }
      }
    },
    "/user/notInterested/{productId}": {
      "post": {
        "summary": "Mark product as not interested",
        "tags": [
          "B2C - Buyer Operations"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "productId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Marked as not interested"
          }
        }
      }
    },
    "/user/wishlist/add/{productId}": {
      "put": {
        "summary": "Add a product to wishlist",
        "tags": [
          "B2C - Buyer Operations"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "productId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Product added to wishlist"
          }
        }
      }
    },
    "/user/wishlist": {
      "get": {
        "summary": "Get wishlist products for current user",
        "tags": [
          "B2C - Buyer Operations"
        ],
        "responses": {
          "200": {
            "description": "Wishlist returned"
          }
        }
      }
    },
    "/user/pendingRequests": {
      "get": {
        "summary": "Get pending product requests for current user",
        "tags": [
          "B2C - Buyer Operations"
        ],
        "responses": {
          "200": {
            "description": "Pending requests returned"
          }
        }
      }
    },
    "/user/wishlist/remove/{productId}": {
      "delete": {
        "summary": "Remove a product from wishlist",
        "tags": [
          "B2C - Buyer Operations"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "productId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Product removed from wishlist"
          }
        }
      }
    },
    "/user/update/password": {
      "patch": {
        "summary": "Update buyer password",
        "tags": [
          "B2C - Auth & Profile"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "oldPassword",
                  "newPassword"
                ],
                "properties": {
                  "oldPassword": {
                    "type": "string"
                  },
                  "newPassword": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password updated successfully"
          }
        }
      }
    },
    "/user/update/profile": {
      "put": {
        "summary": "Update buyer profile (multipart/form-data for profilePic)",
        "tags": [
          "B2C - Auth & Profile"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "contact": {
                    "type": "string"
                  },
                  "profilePic": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profile updated successfully"
          }
        }
      }
    },
    "/user/yourProducts": {
      "get": {
        "summary": "Get products posted by current user",
        "tags": [
          "B2B - Seller Operations"
        ],
        "responses": {
          "200": {
            "description": "User products returned"
          }
        }
      }
    },
    "/user/getYourProfile": {
      "get": {
        "summary": "Get current user's public profile",
        "tags": [
          "B2C - Auth & Profile"
        ],
        "responses": {
          "200": {
            "description": "User profile returned"
          }
        }
      }
    },
    "/user/getNotifications": {
      "get": {
        "summary": "Get notifications for current user",
        "tags": [
          "B2C - Chat & Notifications"
        ],
        "responses": {
          "200": {
            "description": "Notifications returned"
          }
        }
      }
    },
    "/user/notifications/{notificationId}/read": {
      "patch": {
        "summary": "Mark a single notification as read",
        "tags": [
          "B2C - Chat & Notifications"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "notificationId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Notification marked as read"
          }
        }
      }
    },
    "/user/notifications/mark-all-read": {
      "post": {
        "summary": "Mark all notifications as read for current user",
        "tags": [
          "B2C - Chat & Notifications"
        ],
        "responses": {
          "200": {
            "description": "All unread notifications marked as read"
          }
        }
      }
    },
    "/user/notifications/{notificationId}": {
      "delete": {
        "summary": "Delete a single notification for current user",
        "tags": [
          "B2C - Chat & Notifications"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "notificationId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Notification deleted"
          }
        }
      }
    },
    "/user/products": {
      "get": {
        "summary": "Get products where current user is seller",
        "tags": [
          "B2B - Seller Operations"
        ],
        "responses": {
          "200": {
            "description": "Seller products returned"
          }
        }
      }
    },
    "/user/subscriptionStatus": {
      "get": {
        "summary": "Get subscription status for seller",
        "tags": [
          "B2B - Seller Operations"
        ],
        "responses": {
          "200": {
            "description": "Subscription status returned"
